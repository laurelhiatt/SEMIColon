Bootstrap: docker
From: condaforge/miniforge3:26.1.0-0

%arguments

%setup
    
%files

%environment

%post
    export LC_ALL=C.UTF-8
    export CONDA_DIR=/opt/conda
    export CONDA_DEFAULT_ENV=/opt/conda/envs/base
    export CONDA_EXE=/opt/conda/bin/conda
    export CONDA_PREFIX=/opt/conda/envs/base
    export CONDA_PYTHON_EXE=/opt/conda/bin/conda
    export PATH=/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin


    apt-get update
    apt-get install --assume-yes \
        curl wget bzip2 ca-certificates openssl git findutils which tar pigz bc unzip
    
    # Create conda environments.
    conda config --set channel_priority strict
    conda config --append channels bioconda
    conda config --append channels nodefaults
    
    # --- Alfred
    mamba create --name alfred --yes \
        -c bioconda -c conda-forge -c nodefaults \
        _libgcc_mutex=0.1 \
        _openmp_mutex=4.5 \
        alfred=0.3.2 \
        boost-cpp=1.85.0 \
        bzip2=1.0.8 \
        c-ares=1.34.5 \
        ca-certificates=2025.10.5 \
        xz=5.8.1 \
        xz-gpl-tools=5.8.1 \
        xz-tools=5.8.1

    # --- BCFTools
    mamba create --name bcftools --yes \
        bcftools=1.16
    
    # --- Bedtools
    mamba create --name bedtools --yes \
        bedtools=2.31.1
    
    # --- BWA
    mamba create --name bwa --yes \
        bwa=0.7.19
    
    # --- CyVCF2
    mamba create --name cyvcf2 --yes \
        asttokens=3.0.0 \
        biopython=1.85 \
        blas=1.0 \
        bottleneck=1.4.2 \
        comm=0.2.1 \
        cyvcf2=0.31.1 \
        debugpy=1.8.16 \
        decorator=5.2.1 \
        exceptiongroup=1.3.0 \
        executing=2.2.1 \
        ipykernel=6.30.1 \
        ipython=9.1.0 \
        jedi=0.19.2 \
        jupyter_client=8.6.3 \
        jupyter_core=5.8.1 \
        matplotlib-inline=0.1.7 \
        nest-asyncio=1.6.0 \
        numexpr=2.12.1 \
        pandas=2.3.2 \
        parso=0.8.4 \
        pexpect=4.9.0 \
        pickleshare=0.7.5 \
        platformdirs=4.3.7 \
        prompt_toolkit=3.0.43 \
        psutil=7.0.0 \
        ptyprocess=0.7.0 \
        pure_eval=0.2.3 \
        pyfaidx=0.9.0.3 \
        pygments=2.19.1 \
        python-dateutil=2.9.0.post0 \
        python-tzdata=2025.2 \
        python_abi=3.12 \
        pytz=2025.2 \
        pyvcf3=1.0.4 \
        pyzmq=27.1.0 \
        six=1.17.0 \
        stack_data=0.6.3 \
        tornado=6.5.1 \
        traitlets=5.14.3 \
        typing_extensions=4.15.0 \
        wcwidth=0.2.13 \
        zeromq=4.3.5 \
        zipp=3.23.0

    # --- Fastp
    mamba create --name fastp --yes \
        fastp=0.24.0 \
        isa-l=2.31.1

    # --- Freebayes
    mamba create --name freebayes --yes \
        freebayes=1.3.4
    
    # --- InSTRbility
    mamba create --name instrbility --yes \
        filelock=3.25.2 \
        numpy=2.3.1 \
        pysam=0.23.3 \
        scikit-learn=1.8.0 \
        threadpoolctl=3.6.0 \
        pyabpoa=1.5.6 
    
    INSTR_ENV=$( conda env list | grep "instrbility" | grep -o "/.*" ) && \
        cd $INSTR_ENV && \
        git clone https://github.com/laurelhiatt/inSTRbility.git && \
        mv inSTRbility $INSTR_ENV/lib/inSTRbility && \
        ln -s $INSTR_ENV/lib/inSTRbility/inSTRbility/core.py $INSTR_ENV/bin/inSTRbility && \
        chmod +x $INSTR_ENV/lib/inSTRbility/inSTRbility/core.py && \
        chmod +x $INSTR_ENV/bin/inSTRbility
    
    # --- Make_Bams
    mamba create --name make_bams --yes \
        bwa=0.7.19 \
        bzip2=1.0.8 \
        samblaster=0.1.26 \
        samtools=1.21
    
    # --- Mosdepth
    mamba create --name mosdepth --yes \
        mosdepth=0.3.1
    
    # --- Plot_Mosdepth
    mamba create --name plot_mosdepth --yes \
        pip=21.2.2 \
        python=3.6.13 \
        readline=8.2 \
        setuptools=58.0.4 \
        xz=5.6.4 \

    # --- R
    mamba create --name r-env --yes \
        r-base=4.4.2 \
        r-essentials=4.4 \
        r-tidyverse=2.0.0
    
    # --- Recurrent
    mamba create --name recurrent --yes \
        bzip2=1.0.8 \
        jansson=2.14 \
        pip=25.3 \
        pthread-stubs=0.3 \
        pysam=0.23.3 \
        python=3.13.0 \
        readline=8.3 \
        sqlite=3.51.0 \
        tzdata=2025b
    
    # --- Somalier
    mamba create --name somalier --yes \
        somalier=0.3.1
    
    # --- Slivar
    mamba create --name slivar --yes \
        slivar=0.3.1
    
    # --- VCFStats
    mamba create --name vcfstats --yes \
        attr=2.5.1 \
        bcftools=1.22 \
        blas=1.0 \
        brotli-python=1.0.9 \
        bzip2=1.0.8 \
        cairo=1.18.4 \
        contourpy=1.3.1 \
        cycler=0.11.0 \
        cyrus-sasl=2.1.28 \
        freetype=2.13.3 \
        graphite2=1.3.14 \
        gst-plugins-base=1.24.11 \
        gstreamer=1.24.11 \
        harfbuzz=11.2.1 \
        krb5=1.21.3 \
        lame=3.100 \
        matplotlib=3.10.0 \
        matplotlib-base=3.10.0 \
        mpg123=1.32.9 \
        nspr=4.36 \
        nss=3.113 \
        numpy=2.3.1 \
        pcre2=10.45 \
        perl=5.32.1 \
        pillow=11.3.0 \
        pixman=0.46.2 \
        ply=3.11 \
        pyparsing=3.2.0 \
        pyqt=5.15.10 \
        pyqt5-sip=12.13.0 \
        python-dateutil=2.9.0.post0 \
        qt-main=5.15.15 \
        readline=8.2 \
        six=1.17.0 \
        tornado=6.5.1 \
        tzdata=2025b \
        vcftools=0.1.17 
    
    # --- VEP
    mamba create --name vep \
        ensembl-vep=115.2

    # --- VCFExpress
    mamba create --name vcfexpress \
        openssl=3.6.1 \
        wget=1.25.0 

    VCFEXPRESS_ENV=$( conda env list | grep "vcfexpress" | grep -o "/.*" ) && \
        mkdir -p $VCFEXPRESS_ENV/bin && \
        cd $VCFEXPRESS_ENV/bin && \
        mamba run --name vcfexpress \
            wget https://github.com/brentp/vcfexpress/releases/download/v0.3.5/vcfexpress

%runscript

%startscript

%labels

%help